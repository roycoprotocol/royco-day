view","virtual":false,"visibility":"external"},{"documentation":{"id":2019,"nodeType":"StructuredDocumentation","src":"7392:409:11","text":" @notice Deposits assets into the tranche and mints shares to the receiver\n @dev Transfers assets from the caller and mints shares to the receiver\n @param _assets The amount of assets to deposit, denominated in the tranche's base asset units\n @param _receiver The address that will receive the minted shares\n @return shares The number of shares minted to the receiver"},"functionSelector":"6e553f65","id":2029,"implemented":false,"kind":"function","modifiers":[],"name":"deposit","nameLocation":"7815:7:11","nodeType":"FunctionDefinition","parameters":{"id":2025,"nodeType":"ParameterList","parameters":[{"constant":false,"id":2022,"mutability":"mutable","name":"_assets","nameLocation":"7836:7:11","nodeType":"VariableDeclaration","scope":2029,"src":"7823:20:11","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$2228","typeString":"TRANCHE_UNIT"},"typeName":{"id":2021,"nodeType":"UserDefinedTypeName","pathNode":{"id":2020,"name":"TRANCHE_UNIT","nameLocations":["7823:12:11"],"nodeType":"IdentifierPath","referencedDeclaration":2228,"src":"7823:12:11"},"referencedDeclaration":2228,"src":"7823:12:11","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$2228","typeString":"TRANCHE_UNIT"}},"visibility":"internal"},{"constant":false,"id":2024,"mutability":"mutable","name":"_receiver","nameLocation":"7853:9:11","nodeType":"VariableDeclaration","scope":2029,"src":"7845:17:11","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":2023,"name":"address","nodeType":"ElementaryTypeName","src":"7845:7:11","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"}],"src":"7822:41:11"},"returnParamet