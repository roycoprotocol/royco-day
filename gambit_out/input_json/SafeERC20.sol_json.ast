ERC1363} checks when\n targeting contracts.\n NOTE: When the recipient address (`to`) has no code (i.e. is an EOA), this function behaves as {forceApprove}.\n Oppositely, when the recipient address (`to`) has code, this function only attempts to call {ERC1363-approveAndCall}\n once without retrying, and relies on the returned value to be true.\n Reverts if the returned value is other than `true`."},"id":1128,"implemented":true,"kind":"function","modifiers":[],"name":"approveAndCallRelaxed","nameLocation":"7568:21:5","nodeType":"FunctionDefinition","parameters":{"id":1096,"nodeType":"ParameterList","parameters":[{"constant":false,"id":1089,"mutability":"mutable","name":"token","nameLocation":"7599:5:5","nodeType":"VariableDeclaration","scope":1128,"src":"7590:14:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_contract$_IERC1363_$3502","typeString":"contract IERC1363"},"typeName":{"id":1088,"nodeType":"UserDefinedTypeName","pathNode":{"id":1087,"name":"IERC1363","nameLocations":["7590:8:5"],"nodeType":"IdentifierPath","referencedDeclaration":3502,"src":"7590:8:5"},"referencedDeclaration":3502,"src":"7590:8:5","typeDescriptions":{"typeIdentifier":"t_contract$_IERC1363_$3502","typeString":"contract IERC1363"}},"visibility":"internal"},{"constant":false,"id":1091,"mutability":"mutable","name":"to","nameLocation":"7614:2:5","nodeType":"VariableDeclaration","scope":1128,"src":"7606:10:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":1090,"name":"address","nodeType":"ElementaryTypeName","src":"7606:7:5","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"},{"constant":false,"id":1093,"mutability":"mutable","name":"value","nameLocation":"7626:5:5","nodeType":"VariableDeclaration","scope":1128,"src":"7618:13:5","stateVariable":false,"storageLocation":"default","typ