dering is unconstrained: the cache is transient and auto-clears every transaction, so no persistent layout depends on the ordinals"},"id":1259,"members":[{"id":1257,"name":"IDENTICAL_ST_JT_TRANCHE_TO_NAV_UNIT_RATE","nameLocation":"1012:40:10","nodeType":"EnumValue","src":"1012:40:10"},{"id":1258,"name":"ST_SHARE_RATE","nameLocation":"1058:13:10","nodeType":"EnumValue","src":"1058:13:10"}],"name":"CacheKey","nameLocation":"997:8:10","nodeType":"EnumDefinition","src":"992:81:10"},{"abstract":false,"baseContracts":[],"canonicalName":"Cache","contractDependencies":[],"contractKind":"library","documentation":{"id":1260,"nodeType":"StructuredDocumentation","src":"1075:270:10","text":" @title Cache\n @author Waymont\n @notice A unified keyed transient cache usable by any contract: one transient slot per CacheKey derived from a single ERC-7201 base slot, with a top-bit populated marker so a cached zero is distinguishable from an unset slot"},"fullyImplemented":true,"id":1375,"linearizedBaseContracts":[1375],"name":"Cache","nameLocation":"1354:5:10","nodeType":"ContractDefinition","nodes":[{"global":false,"id":1263,"libraryName":{"id":1261,"name":"SlotDerivation","nameLocations":["1372:14:10"],"nodeType":"IdentifierPath","referencedDeclaration":2890,"src":"1372:14:10"},"nodeType":"UsingForDirective","src":"1366:33:10","typeName":{"id":1262,"name":"bytes32","nodeType":"ElementaryTypeName","src":"1391:7:10","typeDescriptions":{"typeIdentifier":"t_bytes32","typeString":"bytes32"}}},{"global":false,"id":1266,"libraryName":{"id":1264,"name":"TransientSlot","nameLocations":["1410:13:10"],"nodeType":"IdentifierPath","referencedDeclaration":3089,"src":"1410:13:10"},"nodeType":"UsingForDirective","src":"1404:32:10","typeName":{"id":1265,"name":"bytes32","nodeType":"ElementaryTypeName","src":"1428:7:10","typeDescriptions":{"typeIdentifier":"t_bytes32","typeString":"bytes32"}}},{"global":false,"id":1270,"libraryName":{"id":1267,"name":"TransientSlot","nameLocations":["1447:13:10"],"nod