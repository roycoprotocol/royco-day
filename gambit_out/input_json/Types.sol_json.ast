:"6003:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":2000,"mutability":"mutable","name":"liquidityUtilizationWAD","nameLocation":"6047:23:5","nodeType":"VariableDeclaration","scope":2011,"src":"6039:31:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1999,"name":"uint256","nodeType":"ElementaryTypeName","src":"6039:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":2002,"mutability":"mutable","name":"fixedTermEndTimestamp","nameLocation":"6083:21:5","nodeType":"VariableDeclaration","scope":2011,"src":"6076:28:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint32","typeString":"uint32"},"typeName":{"id":2001,"name":"uint32","nodeType":"ElementaryTypeName","src":"6076:6:5","typeDescriptions":{"typeIdentifier":"t_uint32","typeString":"uint32"}},"visibility":"internal"},{"constant":false,"id":2004,"mutability":"mutable","name":"minCoverageWAD","nameLocation":"6161:14:5","nodeType":"VariableDeclaration","scope":2011,"src":"6153:22:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":2003,"name":"uint256","nodeType":"ElementaryTypeName","src":"6153:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":2006,"mutability":"mutable","name":"jtCoinvested","nameLocation":"6186:12:5","nodeType":"VariableDeclaration","scope":2011,"src":"6181:17:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"},"typeName":{"id":2005,"name":"bool","nodeType":"ElementaryTypeName","src":"6181:4:5","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"}},"visibility":"internal"},{"constant":false,"id":2008,"mutability":"mutable","name":"coverageLiquidationUtilizationWAD","nameLocation":"6212:33:5","nodeType":"VariableDeclaration","scope":2011,"src":"6204:41:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":2007,"name":"uint256","nodeType":"ElementaryTypeName","src":"6204:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":2010,"mutability":"mutable","name":"minLiquidityWAD","nameLocation":"6303:15:5","nodeType":"VariableDeclaration","scope":2011,"src":"6295:23:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":2009,"name":"uint256","nodeType":"ElementaryTypeName","src":"6295:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"}],"name":"SyncedAccountingState","nameLocation":"5446:21:5","nodeType":"StructDefinition","scope":2025,"src":"5439:882:5","visibility":"public"},{"canonicalName":"Operation","documentation":{"id":2012,"nodeType":"StructuredDocumentation","src":"6323:632:5","text":" @title Operation\n @dev Defines the type of operation being executed by the user\n @custom:type ST_DEPOSIT - A senior tranche deposit that increases ST's effective NAV\n @custom:type ST_REDEEM - A senior tranche redemption that decreases ST's effective NAV\n @custom:type JT_DEPOSIT - A junior tranche deposit that increases JT's effective NAV\n @custom:type JT_REDEEM - A junior tranche redemption that decreases JT's effective NAV\n @custom:type LT_DEPOSIT - A liquidity tranche deposit that increases LT's effective NAV\n @custom:type LT_REDEEM - A liquidity tranche redemption that decreases LT's effective NAV"},"id":2019,"members":[{"id":2013,"name":"ST_DEPOSIT","nameLocation":"6977:10:5","nodeType":"EnumValue","src":"6977:10:5"},{"id":2014,"name":"ST_REDEEM","nameLocation":"6993:9:5","nodeType":"EnumValue","src":"6993:9:5"},{"id":2015,"name":"JT_DEPOSIT","nameLocation":"7008:10:5","nodeType":"EnumValue","src":"7008:10:5"},{"id":2016,"name":"JT_REDEEM","nameLocation":"7024:9:5","nodeType":"EnumValue","src":"7024:9:5"},{"id":2017,"name":"LT_DEPOSIT","nameLocation":"7039:10:5","nodeType":"EnumValue","src":"7039:10:5"},{"id":2018,"name":"LT_REDEEM","nameLocation":"7055:9:5","nodeType":"EnumValue","src":"7055:9:5"}],"name":"Operation","nameLocation":"6961:9:5","nodeType":"EnumDefinition","src":"6956:110:5"},{"canonicalName":"TrancheType","documentation":{"id":2020,"nodeType":"StructuredDocumentation","src":"7068:354:5","text":" @title TrancheType\n @dev Defines the types of Royco tranches deployed per market.\n @custom:type SENIOR - The identifier for the senior tranche (protected capital)\n @custom:type JUNIOR - The identifier for the junior tranche (first-loss capital)\n @custom:type LIQUIDITY - The identifier for the liquidity tranche (market-making capital)"},"id":2024,"members":[{"id":2021,"name":"SENIOR","nameLocation":"7446:6:5","nodeType":"EnumValue","src":"7446:6:5"},{"id":2022,"name":"JUNIOR","nameLocation":"7458:6:5","nodeType":"EnumValue","src":"7458:6:5"},{"id":2023,"name":"LIQUIDITY","nameLocation":"7470:9:5","nodeType":"EnumValue","src":"7470:9:5"}],"name":"TrancheType","nameLocation":"7428:11:5","nodeType":"EnumDefinition","src":"7423:58:5"}],"src":"39:7444:5"}