{"absolutePath":"src/libraries/Types.sol","exportedSymbols":{"AssetClaims":[1962],"MarketState":[1946],"NAV_UNIT":[971],"Operation":[2019],"SyncedAccountingState":[2011],"TRANCHE_UNIT":[973],"TrancheType":[2024]},"id":2025,"license":"UNLICENSED","nodeType":"SourceUnit","nodes":[{"id":1939,"literals":["solidity","^","0.8",".28"],"nodeType":"PragmaDirective","src":"39:24:5"},{"absolutePath":"src/libraries/Units.sol","file":"./Units.sol","id":1942,"nameLocation":"-1:-1:-1","nodeType":"ImportDirective","scope":2025,"sourceUnit":1938,"src":"65:53:5","symbolAliases":[{"foreign":{"id":1940,"name":"NAV_UNIT","nodeType":"Identifier","overloadedDeclarations":[],"referencedDeclaration":971,"src":"74:8:5","typeDescriptions":{}},"nameLocation":"-1:-1:-1"},{"foreign":{"id":1941,"name":"TRANCHE_UNIT","nodeType":"Identifier","overloadedDeclarations":[],"referencedDeclaration":973,"src":"84:12:5","typeDescriptions":{}},"nameLocation":"-1:-1:-1"}],"unitAlias":""},{"canonicalName":"MarketState","documentation":{"id":1943,"nodeType":"StructuredDocumentation","src":"120:1809:5","text":" @title MarketState\n @notice Defines the operational state of a Royco market\n @custom:state PERPETUAL\n      Normal operating state where market forces govern behavior\n      - The market is healthy (no losses over dust tolerance) or it is severely undercollateralized (liquidation coverage utilization breach) or uncollateralized (no remaining JT NAV with non-zero ST NAV)\n      - All three tranches are liquid (within coverage and liquidity constraints)\n      - In an under/uncollateralized state, the LT is treated identically to the ST with regard to its liquidity profile (liquidity requirement is exempt from being fulfilled)\n      - Adaptive curve YDMs adapt based on the coverage and liquidity utilization of this market\n @custom:state FIXED_TERM\n      Temporary recovery state triggered when JT provides coverage for ST drawdown\n      - ST experienced a fully covered drawdown but the market is still healthy in terms of its liquidation coverage utilization threshold\n      - The fixed-term starts when (non-dust) JT coverage impermanent loss is first incurred\n      - ST deposits/redemptions blocked: protects existing JT from realizing losses by ST withdrawing coverage on arbitrary volatility\n      - JT deposits/redemptions blocked: protects existing JT from realizing losses by new JT diluting them on arbitrary volatility\n      - LT redemptions blocked: Guarantees that the LT continues market making the ST when secondary liquidity is most valuable\n      - Adaptive curve YDM does not adapt (prevents adaptation during recovery since market forces aren't influencing coverage or liquidity utilization, underlying PNL is\n      - Automatically transitions to PERPETUAL when losses are recovered or the term elapses, clearing JT coverage impermanent losses"},"id":1946,"members":[{"id":1944,"name":"PERPETUAL","nameLocation":"1953:9:5","nodeType":"EnumValue","src":"1953:9:5"},{"id":1945,"name":"FIXED_TERM","nameLocation":"1968:10:5","nodeType":"EnumValue","src":"1968:10:5"}],"name":"MarketState","nameLocation":"1935:11:5","nodeType":"EnumDefinition","src":"1930:50:5"},{"canonicalName":"AssetClaims","documentation":{"id":1947,"nodeType":"StructuredDocumentation","src":"1982:708:5","text":" @title AssetClaims\n @dev A struct representing claims on senior tranche assets, junior tranche assets, liquidity tranche assets, and NAV\n @custom:field stAssets - The claim on senior tranche assets denominated in ST's tranche units (only applicable for the ST and JT)\n @custom:field jtAssets - The claim on junior tranche assets denominated in JT's tranche units (only applicable for the ST and JT)\n @custom:field ltAssets - The claim on liquidity tranche assets denominated in LT's tranche units (only applicable for the LT)\n @custom:field stShares - The claim on senior tranche shares (only applicable for the LT)\n @custom:field nav - The net asset value of these claims in NAV units"},"id":1962,"members":[{"constant":false,"id":1950,"mutability":"mutable","name":"stAssets","nameLocation":"2753:8:5","nodeType":"VariableDeclaration","scope":1962,"src":"2740:21:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":1949,"nodeType":"UserDefinedTypeName","pathNode":{"id":1948,"name":"TRANCHE_UNIT","nameLocations":["2740:12:5"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"2740:12:5"},"referencedDeclaration":973,"src":"2740:12:5","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"},{"constant":false,"id":1953,"mutability":"mutable","name":"jtAssets","nameLocation":"2780:8:5","nodeType":"VariableDeclaration","scope":1962,"src":"2767:21:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":1952,"nodeType":"UserDefinedTypeName","pathNode":{"id":1951,"name":"TRANCHE_UNIT","nameLocations":["2767:12:5"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"2767:12:5"},"referencedDeclaration":973,"src":"2767:12:5","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"},{"constant":false,"id":1956,"mutability":"mutable","name":"ltAssets","nameLocation":"2824:8:5","nodeType":"VariableDeclaration","scope":1962,"src":"2811:21:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":1955,"nodeType":"UserDefinedTypeName","pathNode":{"id":1954,"name":"TRANCHE_UNIT","nameLocations":["2811:12:5"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"2811:12:5"},"referencedDeclaration":973,"src":"2811:12:5","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"},{"constant":false,"id":1958,"mutability":"mutable","name":"stShares","nameLocation":"2846:8:5","nodeType":"VariableDeclaration","scope":1962,"src":"2838:16:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1957,"name":"uint256","nodeType":"ElementaryTypeName","src":"2838:7:5","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":1961,"mutability":"mutable","name":"nav","nameLocation":"2912:3:5","nodeType":"VariableDeclaration","scope":1962,"src":"2903:12:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":1960,"nodeType":"UserDefinedTypeName","pathNode":{"id":1959,"name":"NAV_UNIT","nameLocations":["2903:8:5"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"2903:8:5"},"referencedDeclaration":971,"src":"2903:8:5","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"}],"name":"AssetClaims","nameLocation":"2698:11:5","nodeType":"StructDefinition","scope":2025,"src":"2691:227:5","visibility":"public"},{"canonicalName":"SyncedAccountingState","documentation":{"id":1963,"nodeType":"StructuredDocumentation","src":"2920:2518:5","text":" @title SyncedAccountingState\n @dev Contains all current mark-to-market NAV accounting data for the market's tranches\n @custom:field marketState - The current state of the Royco market (perpetual or fixed term)\n @custom:field stRawNAV - The senior tranche's current raw NAV: the pure value of its invested assets\n @custom:field jtRawNAV - The junior tranche's current raw NAV: the pure value of its invested assets\n @custom:field ltRawNAV - The liquidity tranche's current raw NAV: the pure value of its invested assets\n @custom:field stEffectiveNAV - Senior tranche effective NAV: includes applied coverage, its share of ST yield, and uncovered losses\n @custom:field jtEffectiveNAV - Junior tranche effective NAV: includes provided coverage, JT yield, its share of ST yield, and JT losses\n @custom:field jtCoverageImpermanentLoss - The impermanent loss that JT has suffered after providing coverage for ST losses\n                                   This represents the claim on capital that the junior tranche has on future ST recoveries\n @custom:field ltLiquidityPremium - The liquidity premium accrued to the liquidity tranche on this sync: LT's share of senior yield, minted as senior tranche shares to LT (coverage-neutral)\n @custom:field stProtocolFee - Protocol fee taken on ST yield on this sync\n @custom:field jtProtocolFee - Protocol fee taken on JT yield on this sync\n @custom:field ltProtocolFee - Protocol fee taken on the liquidity premium (LT yield share) on this sync\n @custom:field coverageUtilizationWAD - The current coverageUtilization of the market, scaled to WAD precision\n @custom:field liquidityUtilizationWAD - The current liquidityUtilization of the market, scaled to WAD precision\n @custom:field fixedTermEndTimestamp - The timestamp at which the fixed term ends. Set to 0 if the market is not in a fixed term state\n @custom:field minCoverageWAD - The coverage percentage that the senior tranche is expected to be protected by, scaled to WAD precision\n @custom:field jtCoinvested - Whether the junior tranche is co-invested in the same yield-bearing opportunity as senior (true means it shares senior's downside stress) or in the RFR (false)\n @custom:field coverageLiquidationUtilizationWAD - The liquidation coverageUtilization threshold for this market, scaled to WAD precision\n @custom:field minLiquidityWAD - The percentage of the senior tranche NAV that must be in the liquidity tranche's market making inventory, scaled to WAD precision"},"id":2011,"members":[{"constant":false,"id":1966,"mutability":"mutable","name":"marketState","nameLocation":"5556:11:5","nodeType":"VariableDeclaration","scope":2011,"src":"5544:23:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_enum$_MarketState_$1946","typeString":"enum MarketState"},"typeName":{"id":1965,"nodeType":"UserDefinedTypeName","pathNode":{"id":1964,"name":"MarketState","nameLocations":["5544:11:5"],"nodeType":"IdentifierPath","referencedDeclaration":1946,"src":"5544:11:5"},"referencedDeclaration":1946,"src":"5544:11:5","typeDescriptions":{"typeIdentifier":"t_enum$_MarketState_$1946","typeString":"enum MarketState"}},"visibility":"internal"},{"constant":false,"id":1969,"mutability":"mutable","name":"stRawNAV","nameLocation":"5686:8:5","nodeType":"VariableDeclaration","scope":2011,"src":"5677:17:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":1968,"nodeType":"UserDefinedTypeName","pathNode":{"id":1967,"name":"NAV_UNIT","nameLocations":["5677:8:5"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"5677:8:5"},"referencedDeclaration":971,"src":"5677:8:5","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":1972,"mutability":"mutable","name":"jtRawNAV","nameLocation":"5709:8:5","nodeType":"VariableDeclaration","scope":2011,"src":"5700:17:5","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":1971,"nodeType":"UserDefinedTypeName","pathNode":{"id":1970,"name":"NAV_UNIT","nameLocations":["5700:8:5"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"5700:8:5"},"referencedDeclaration":971,"src":"5700:8:5","typeDescriptions"