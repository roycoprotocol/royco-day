{"absolutePath":"src/interfaces/IRoycoSeniorTranche.sol","exportedSymbols":{"IRoycoSeniorTranche":[1054],"IRoycoVaultTranche":[1249]},"id":1055,"license":"UNLICENSED","nodeType":"SourceUnit","nodes":[{"id":1029,"literals":["solidity","^","0.8",".28"],"nodeType":"PragmaDirective","src":"39:24:8"},{"absolutePath":"src/interfaces/IRoycoVaultTranche.sol","file":"./IRoycoVaultTranche.sol","id":1031,"nameLocation":"-1:-1:-1","nodeType":"ImportDirective","scope":1055,"sourceUnit":1250,"src":"65:62:8","symbolAliases":[{"foreign":{"id":1030,"name":"IRoycoVaultTranche","nodeType":"Identifier","overloadedDeclarations":[],"referencedDeclaration":1249,"src":"74:18:8","typeDescriptions":{}},"nameLocation":"-1:-1:-1"}],"unitAlias":""},{"abstract":false,"baseContracts":[{"baseName":{"id":1033,"name":"IRoycoVaultTranche","nameLocations":["733:18:8"],"nodeType":"IdentifierPath","referencedDeclaration":1249,"src":"733:18:8"},"id":1034,"nodeType":"InheritanceSpecifier","src":"733:18:8"}],"canonicalName":"IRoycoSeniorTranche","contractDependencies":[],"contractKind":"interface","documentation":{"id":1032,"nodeType":"StructuredDocumentation","src":"129:570:8","text":" @title IRoycoSeniorTranche\n @notice Interface for the senior tranche (ST): the standard share-token surface (inherited from IRoycoVaultTranche) plus\n         the senior-specific liquidity premium share mint, by which the kernel routes senior yield to the liquidity tranche\n         as newly minted senior shares\n @dev Only the senior tranche carries this mint: the liquidity premium is a reassignment of senior appreciation, so it is\n      paid as senior shares. The junior and liquidity tranches share the base IRoycoVaultTranche surface without it"},"fullyImplemented":false,"id":1054,"linearizedBaseContracts":[1054,1249,2760,361],"name":"IRoycoSeniorTranche","nameLocation":"710:19:8","nodeType":"ContractDefinition","nodes":[{"anonymous":false,"documentation":{"id":1035,"nodeType":"StructuredDocumentation","src":"758:476:8","text":" @notice Emitted when liquidity premium shares are minted to the kernel on behalf of the liquidity tranche\n @param holder The address that received the minted premium shares (the kernel, which custodies them for the liquidity tranche)\n @param mintedLiquidityPremiumShares The number of senior shares minted as the liquidity premium\n @param totalTrancheShares The total shares in the senior tranche after minting the liquidity premium shares"},"eventSelector":"64bd7263a158ae715b9e1cecdfab98c920f5d7edeec5f2eba3ddb17aa8ce0b16","id":1043,"name":"LiquidityPremiumSharesMinted","nameLocation":"1245:28:8","nodeType":"EventDefinition","parameters":{"id":1042,"nodeType":"ParameterList","parameters":[{"constant":false,"id":1037,"indexed":true,"mutability":"mutable","name":"holder","nameLocation":"1290:6:8","nodeType":"VariableDeclaration","scope":1043,"src":"1274:22:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":1036,"name":"address","nodeType":"ElementaryTypeName","src":"1274:7:8","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"},{"constant":false,"id":1039,"indexed":false,"mutability":"mutable","name":"mintedLiquidityPremiumShares","nameLocation":"1306:28:8","nodeType":"VariableDeclaration","scope":1043,"src":"1298:36:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1038,"name":"uint256","nodeType":"ElementaryTypeName","src":"1298:7:8","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":1041,"indexed":false,"mutability":"mutable","name":"totalTrancheShares","nameLocation":"1344:18:8","nodeType":"VariableDeclaration","scope":1043,"src":"1336:26:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1040,"name":"uint256","nodeType":"ElementaryTypeName","src":"1336:7:8","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"}],"src":"1273:90:8"},"src":"1239:125:8"},{"documentation":{"id":1044,"nodeType":"StructuredDocumentation","src":"1370:962:8","text":" @notice Mints a kernel-computed number of liquidity premium shares to the specified holder\n @dev Only callable by the kernel during accounting synchronization\n @dev The liquidity premium is senior yield routed to the liquidity tranche, minted as senior tranche shares held by\n      the kernel on the LT's behalf. This leaves the senior raw NAV (and thus coverage) unchanged, so the mint is\n      coverage-neutral and only reassigns senior appreciation to the LT\n @dev Takes a precomputed share count, priced jointly with the ST protocol fee so neither carve-out dilutes the other\n @param _to The account to mint the premium shares to (the kernel, which custodies them for the liquidity tranche)\n @param _liquidityPremiumShares The precomputed number of liquidity premium shares to mint\n @return totalTrancheShares The total shares in the senior tranche after minting the liquidity premium shares"},"functionSelector":"11dbb70f","id":1053,"implemented":false,"kind":"function","modifiers":[],"name":"mintLiquidityPremiumShares","nameLocation":"2346:26:8","nodeType":"FunctionDefinition","parameters":{"id":1049,"nodeType":"ParameterList","parameters":[{"constant":false,"id":1046,"mutability":"mutable","name":"_to","nameLocation":"2381:3:8","nodeType":"VariableDeclaration","scope":1053,"src":"2373:11:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":1045,"name":"address","nodeType":"ElementaryTypeName","src":"2373:7:8","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"},{"constant":false,"id":1048,"mutability":"mutable","name":"_liquidityPremiumShares","nameLocation":"2394:23:8","nodeType":"VariableDeclaration","scope":1053,"src":"2386:31:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1047,"name":"uint256","nodeType":"ElementaryTypeName","src":"2386:7:8","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"}],"src":"2372:46:8"},"returnParameters":{"id":1052,"nodeType":"ParameterList","parameters":[{"constant":false,"id":1051,"mutability":"mutable","name":"totalTrancheShares","nameLocation":"2445:18:8","nodeType":"VariableDeclaration","scope":1053,"src":"2437:26:8","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":1050,"name":"uint256","nodeType":"ElementaryTypeName","src":"2437:7:8","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"}],"src":"2436:28:8"},"scope":1054,"src":"2337:128:8","stateMutability":"nonpayable","virtual":false,"visibility":"external"}],"scope":1055,"src":"700:1767:8","usedErrors":[1111,1114,1117,1120],"usedEvents":[295,304,1043,1087,1099,1108]}],"src":"39:2429:8"}