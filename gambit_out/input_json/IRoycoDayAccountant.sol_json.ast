236:388:12","text":" @notice Emitted when the maximum JT and LT yield shares (premiums) are updated\n @param maxJTYieldShareWAD The new maximum JT yield share (risk premium) as a percentage of senior appreciation, scaled to WAD precision\n @param maxLTYieldShareWAD The new maximum LT yield share (liquidity premium) as a percentage of senior appreciation, scaled to WAD precision"},"eventSelector":"7fb1e83625dc711ae7e24be2cc4de4a596d84eca0e49f56ea98b0b9e38f407c0","id":844,"name":"MaxYieldSharesUpdated","nameLocation":"15635:21:12","nodeType":"EventDefinition","parameters":{"id":843,"nodeType":"ParameterList","parameters":[{"constant":false,"id":840,"indexed":false,"mutability":"mutable","name":"maxJTYieldShareWAD","nameLocation":"15664:18:12","nodeType":"VariableDeclaration","scope":844,"src":"15657:25:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint64","typeString":"uint64"},"typeName":{"id":839,"name":"uint64","nodeType":"ElementaryTypeName","src":"15657:6:12","typeDescriptions":{"typeIdentifier":"t_uint64","typeString":"uint64"}},"visibility":"internal"},{"constant":false,"id":842,"indexed":false,"mutability":"mutable","name":"maxLTYieldShareWAD","nameLocation":"15691:18:12","nodeType":"VariableDeclaration","scope":844,"src":"15684:25:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint64","typeString":"uint64"},"typeName":{"id":841,"name":"uint64","nodeType":"ElementaryTypeName","src":"15684:6:12","typeDescriptions":{"typeIdentifier":"t_uint64","typeString":"uint64"}},"visibility":"internal"}],"src":"15656:54:12"},"src":"15629:82:12"},{"documentation":{"id":845,"nodeType":"StructuredDocumentation","src":"15717:98:12","text":"@notice Thrown when the caller of the function is not the accountant's configured Royco Kernel"},"errorSelector":"c5004c68","id":847,"name":"ONLY_ROYCO_KERNEL","nameLocation":"15826:17:12","nodeType":"ErrorDefinition","parameters":{"id":846,"nodeTyp