ty":"internal"}],"src":"14187:42:12"},"src":"14140:90:12"},{"anonymous":false,"documentation":{"id":820,"nodeType":"StructuredDocumentation","src":"14236:68:12","text":"@notice Emitted when a fixed term regime is ended by this market"},"eventSelector":"7f4b75d303fd8bc92ac04d35ab04366959f30c52806469e437233b9fa47d8c58","id":822,"name":"FixedTermEnded","nameLocation":"14315:14:12","nodeType":"EventDefinition","parameters":{"id":821,"nodeType":"ParameterList","parameters":[],"src":"14329:2:12"},"src":"14309:23:12"},{"anonymous":false,"documentation":{"id":823,"nodeType":"StructuredDocumentation","src":"14338:143:12","text":"@notice Emitted when the LT YDM (liquidity tranche Yield Distribution Model) address is updated\n @param ltYDM The new LT YDM address"},"eventSelector":"9a1658bf1397d9fbc2b7f1130212f1fa87b09871125466a6e867c3fb9907e489","id":827,"name":"LiquidityTrancheYDMUpdated","nameLocation":"14492:26:12","nodeType":"EventDefinition","parameters":{"id":826,"nodeType":"ParameterList","parameters":[{"constant":false,"id":825,"indexed":false,"mutability":"mutable","name":"ltYDM","nameLocation":"14527:5:12","nodeType":"VariableDeclaration","scope":827,"src":"14519:13:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":824,"name":"address","nodeType":"ElementaryTypeName","src":"14519:7:12","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"}],"src":"14518:15:12"},"src":"14486:48:12"},{"anonymous":false,"documentation":{"id":828,"nodeType":"StructuredDocumentation","src":"14540:304:12","text":"@notice Emitted when the yield share (liquidity premium) protocol fee percentage is updated\n @param ltYieldShareProtocolFeeWAD The new protocol fee percentage charged from the yield share (liquidity premium) payed from the senior tranche yield to the liquidity tranche, scaled to WAD precision"},"eventSelector":"33