iquidity tranche YDMs are identical"},"errorSelector":"9d7d08de","id":862,"name":"YDMS_CANNOT_BE_IDENTICAL","nameLocation":"16603:24:12","nodeType":"ErrorDefinition","parameters":{"id":861,"nodeType":"ParameterList","parameters":[],"src":"16627:2:12"},"src":"16597:33:12"},{"documentation":{"id":863,"nodeType":"StructuredDocumentation","src":"16636:124:12","text":"@notice Thrown when the YDM failed to initialize\n @param data The return data of the reverting YDM initialization"},"errorSelector":"3cb826c1","id":867,"name":"FAILED_TO_INITIALIZE_YDM","nameLocation":"16771:24:12","nodeType":"ErrorDefinition","parameters":{"id":866,"nodeType":"ParameterList","parameters":[{"constant":false,"id":865,"mutability":"mutable","name":"data","nameLocation":"16802:4:12","nodeType":"VariableDeclaration","scope":867,"src":"16796:10:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_bytes_memory_ptr","typeString":"bytes"},"typeName":{"id":864,"name":"bytes","nodeType":"ElementaryTypeName","src":"16796:5:12","typeDescriptions":{"typeIdentifier":"t_bytes_storage_ptr","typeString":"bytes"}},"visibility":"internal"}],"src":"16795:12:12"},"src":"16765:43:12"},{"documentation":{"id":868,"nodeType":"StructuredDocumentation","src":"16814:106:12","text":"@notice Thrown when the sum of the raw NAVs don't equal the sum of the effective NAVs of both tranches"},"errorSelector":"a0f9517d","id":870,"name":"NAV_CONSERVATION_VIOLATION","nameLocation":"16931:26:12","nodeType":"ErrorDefinition","parameters":{"id":869,"nodeType":"ParameterList","parameters":[],"src":"16957:2:12"},"src":"16925:35:12"},{"documentation":{"id":871,"nodeType":"StructuredDocumentation","src":"16966:183:12","text":"@notice Thrown when the combined risk and liquidity premiums exceed the senior gain they are drawn from: the JT and LT yield shares must sum to at most 100% of senior appreciation"},"errorSelector":"2b0fdc80","id":873,"name":"PREMIUMS_EXCEED_SENIOR_YIELD","nameLocation":"17160:28:12","nodeType":"ErrorDefinition","parameters":{"id":872,"nodeType":"ParameterList","parameters":[],"src":"17188:2:12"},"src":"17154:37:12"},{"documentation":{"id":874,"nodeType":"StructuredDocumentation","src":"17197:89:12","text":"@notice Thrown when the operation and NAVs passed to post-op lead to an invalid state"},"errorSelector":"998eeacb","id":879,"name":"INVALID_POST_OP_STATE","nameLocation":"17297:21:12","nodeType":"ErrorDefinition","parameters":{"id":878,"nodeType":"ParameterList","parameters":[{"constant":false,"id":877,"mutability":"mutable","name":"_op","nameLocation":"17329:3:12","nodeType":"VariableDeclaration","scope":879,"src":"17319:13:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_enum$_Operation_$1829","typeString":"enum Operation"},"typeName":{"id":876,"nodeType":"UserDefinedTypeName","pathNode":{"id":875,"name":"Operation","nameLocations":["17319:9:12"],"nodeType":"IdentifierPath","referencedDeclaration":1829,"src":"17319:9:12"},"referencedDeclaration":1829,"src":"17319:9:12","typeDescriptions":{"typeIdentifier":"t_enum$_Operation_$1829","typeString":"enum Operation"}},"visibility":"internal"}],"src":"17318:15:12"},"src":"17291:43:12"},{"documentation":{"id":880,"nodeType":"StructuredDocumentation","src":"17340:69:12","text":"@notice Thrown when the market's coverage requirement is violated"},"errorSelector":"70834e7b","id":882,"name":"COVERAGE_REQUIREMENT_VIOLATED","nameLocation":"17420:29:12","nodeType":"ErrorDefinition","parameters":{"id":881,"nodeType":"ParameterList","parameters":[],"src":"17449:2:12"},"src":"17414:38:12"},{"documentation":{"id":883,"nodeType":"StructuredDocumentation","src":"17458:70:12","text":"@notice Thrown when the market's liquidity requirement is violated"},"errorSelector":"19364170","id":885,"name":"LIQUIDITY_REQUIREMENT_VIOLATED","nameLocation":"17539:30:12","nodeType":"ErrorDefinition","parameters":{"id":884,"nodeType":"ParameterList","parameters":[],"src":"17569:2:12"},"src":"17533:39:12"},{"documentation":{"id":886,"nodeType":"StructuredDocumentation","src":"17578:209:12","text":"@notice Retrieves the address of the kernel tied to this accountant\n @return kernel The kernel that this accountant maintains mark-to-market NAV, JT coverage impermanent loss, and fee accounting for"},"functionSelector":"037c6514","id":891,"implemented":false,"kind":"function","modifiers":[],"name":"KERNEL","nameLocation":"17801:6:12","nodeType":"FunctionDefinition","parameters":{"id":887,"nodeType":"ParameterList","parameters":[],"src":"17807:2:12"},"returnParameters":{"id":890,"nodeType":"ParameterList","parameters":[{"constant":false,"id":889,"mutability":"mutable","name":"kernel","nameLocation":"17841:6:12","nodeType":"VariableDeclaration","scope":891,"src":"17833:14:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":888,"name":"address","nodeType":"ElementaryTypeName","src":"17833:7:12","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"}],"src":"17832:16:12"},"scope":1081,"src":"17792:57:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":892,"nodeType":"StructuredDocumentation","src":"17855:361:12","text":"@notice Whether the junior tranche is co-invested in the same yield-bearing opportunity as senior (shares senior's downside stress) or in a risk-free opportunity (cash, TBILLs, Aave Core, etc.) with respect to NAV units\n @return jtCoinvested True if the junior tranche is co-invested with the senior tranche, false if it is in a risk-free opportunity"},"functionSelector":"f0f78910","id":897,"implemented":false,"kind":"function","modifiers":[],"name":"JT_COINVESTED","nameLocation":"18230:13:12","nodeType":"FunctionDefinition","parameters":{"id":893,"nodeType":"ParameterList","parameters":[],"src":"18243:2:12"},"returnParameters":{"id":896,"nodeType":"ParameterList","parameters":[{"constant":false,"id":895,"mutability":"mutable","name":"jtCoinvested","nameLocation":"18274:12:12","nodeType":"VariableDeclaration","scope":897,"src":"18269:17:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"},"typeName":{"id":894,"name":"bool","nodeType":"ElementaryTypeName","src":"18269:4:12","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"}},"visibility":"internal"}],"src":"18268:19:12"},"scope":1081,"src":"18221:67:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":898,"nodeType":"StructuredDocumentation","src":"18294:1038:12","text":" @notice Synchronizes the effective NAVs and impermanent losses of both tranches by marking them to market\n @dev Must be called before any NAV mutating operation\n @dev Accrues JT yield share over time based on the market's JT YDM output\n @dev Persists updated NAV and impermanent loss checkpoints for the next sync to use as reference\n @param _stRawNAV The senior tranche's current raw NAV: the pure value of its invested assets\n @param _jtRawNAV The junior tranche's current raw NAV: the pure value of its invested assets\n @return state The synced NAV, impermanent loss, and fee accounting containing all mark-to-market accounting data\n @dev The returned state's ltRawNAV and liquidityUtilizationWAD are zero placeholders: this sync does not mark the liquidity\n      tranche. The kernel commits the freshly marked liquidity tranche raw NAV via commitLiquidityTrancheRawNAV after minting the\n      fee shares, then refreshes both fields in the state packet in memory"},"functionSelector":"1d5a50cd","id":910,"implemented":false,"kind":"function","modifiers":[],"name":"preOpSyncTrancheAccounting","nameLocation":"19346:26:12","nodeType":"FunctionDefinition","parameters":{"id":905,"nodeType":"ParameterList","parameters":[{"constant":false,"id":901,"mutability":"mutable","name":"_stRawNAV","nameLocation":"19382:9:12","nodeType":"VariableDeclaration","scope":910,"src":"19373:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":900,"nodeType":"UserDefinedTypeName","pathNode":{"id":899,"name":"NAV_UNIT","nameLocations":["19373:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"19373:8:12"},"referencedDeclaration":1840,"src":"19373:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":904,"mutability":"mutable","name":"_jtRawNAV","nameLocation":"19402:9:12","nodeType":"VariableDeclaration","scope":910,"src":"19393:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":903,"nodeType":"UserDefinedTypeName","pathNode":{"id":902,"name":"NAV_UNIT","nameLocations":["19393:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"19393:8:12"},"referencedDeclaration":1840,"src":"19393:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"19372:40:12"},"returnParameters":{"id":909,"nodeType":"ParameterList","parameters":[{"constant":false,"id":908,"mutability":"mutable","name":"state","nameLocation":"19460:5:12","nodeType":"VariableDeclaration","scope":910,"src":"19431:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":907,"nodeType":"UserDefinedTypeName","pathNode":{"id":906,"name":"SyncedAccountingState","nameLocations":["19431:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"19431:21:12"},"referencedDeclaration":1821,"src":"19431:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"19430:36:12"},"scope":1081,"src":"19337:130:12","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":911,"nodeType":"StructuredDocumentation","src":"19473:646:12","text":" @notice Previews a synchronization of the effective NAVs and impermanent losses of both tranches by marking them to market\n @param _stRawNAV The senior tranche's current raw NAV: the pure value of its invested assets\n @param _jtRawNAV The junior tranche's current raw NAV: the pure value of its invested assets\n @return state The synced NAV, impermanent loss, and fee accounting containing all mark-to-market accounting data\n @dev The returned state's ltRawNAV and liquidityUtilizationWAD are zero placeholders (this sync does not mark the liquidity tranche). The kernel preview refreshes them in memory"},"functionSelector":"07ede09e","id":923,"implemented":false,"kind":"function","modifiers":[],"name":"previewSyncTrancheAccounting","nameLocation":"20133:28:12","nodeType":"FunctionDefinition","parameters":{"id":918,"nodeType":"ParameterList","parameters":[{"constant":false,"id":914,"mutability":"mutable","name":"_stRawNAV","nameLocation":"20171:9:12","nodeType":"VariableDeclaration","scope":923,"src":"20162:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":913,"nodeType":"UserDefinedTypeName","pathNode":{"id":912,"name":"NAV_UNIT","nameLocations":["20162:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"20162:8:12"},"referencedDeclaration":1840,"src":"20162:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":917,"mutability":"mutable","name":"_jtRawNAV","nameLocation":"20191:9:12","nodeType":"VariableDeclaration","scope":923,"src":"20182:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":916,"nodeType":"UserDefinedTypeName","pathNode":{"id":915,"name":"NAV_UNIT","nameLocations":["20182:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"20182:8:12"},"referencedDeclaration":1840,"src":"20182:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"20161:40:12"},"returnParameters":{"id":922,"nodeType":"ParameterList","parameters":[{"constant":false,"id":921,"mutability":"mutable","name":"state","nameLocation":"20254:5:12","nodeType":"VariableDeclaration","scope":923,"src":"20225:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":920,"nodeType":"UserDefinedTypeName","pathNode":{"id":919,"name":"SyncedAccountingState","nameLocations":["20225:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"20225:21:12"},"referencedDeclaration":1821,"src":"20225:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"20224:36:12"},"scope":1081,"src":"20124:137:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":924,"nodeType":"StructuredDocumentation","src":"20267:2194:12","text":" @notice Applies post-operation (deposit or redemption) raw NAV deltas to effective NAV checkpoints, commits the liquidity tranche's fresh raw NAV, and optionally enforces the market requirement(s) the operation can worsen\n @dev Strictly interprets NAV deltas as deposits/redemptions instead of PNL\n @dev Unlike the pre-op sync, the post-op sync runs no waterfall and pays no premium, so it can commit the liquidity tranche raw NAV\n      directly (the kernel marks it after the operation's pool mutation has settled) and report the resulting liquidity utilization\n @dev When enforcement is requested, fails fast on the coverage requirement for operations that can worsen coverage (add senior exposure or\n      remove the junior loss-absorption buffer: ST_DEPOSIT, LT_DEPOSIT, JT_REDEEM) and on the liquidity requirement for operations that can\n      worsen liquidity (raise the senior effective NAV or reduce the depth of the AMM or another market-making venue: ST_DEPOSIT, the multi-asset\n      LT_DEPOSIT, and an LT_REDEEM that pays no self-liquidation bonus). A bonus-paying LT_REDEEM is a liquidation-breach exit and is exempt.\n      Intermediate multi-asset sub-syncs pass false, deferring enforcement to the final post-op sync that books the combined exposure\n @param _op The operation being executed in between the pre and post operation synchronizations\n @param _stRawNAV The post-op senior tranche's raw NAV\n @param _jtRawNAV The post-op junior tranche's raw NAV\n @param _ltRawNAV The post-op liquidity tranche's freshly marked raw NAV (the oracle value of the AMM or another market-making venue), committed by this call\n @param _stSelfLiquidationBonusNAV The self-liquidation bonus remitted to an ST LP on redemption after the liquidation coverageUtilization threshold has been breached, sourced from JT effective NAV\n @param _enforceCoverageAndLiquidityRequirements Whether to enforce the market's coverage and liquidity requirements applicable to the operation\n @return state The synced NAV, impermanent loss, and fee accounting containing all mark-to-market accounting data"},"functionSelector":"a60ea0b2","id":947,"implemented":false,"kind":"function","modifiers":[],"name":"postOpSyncTrancheAccounting","nameLocation":"22475:27:12","nodeType":"FunctionDefinition","parameters":{"id":942,"nodeType":"ParameterList","parameters":[{"constant":false,"id":927,"mutability":"mutable","name":"_op","nameLocation":"22522:3:12","nodeType":"VariableDeclaration","scope":947,"src":"22512:13:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_enum$_Operation_$1829","typeString":"enum Operation"},"typeName":{"id":926,"nodeType":"UserDefinedTypeName","pathNode":{"id":925,"name":"Operation","nameLocations":["22512:9:12"],"nodeType":"IdentifierPath","referencedDeclaration":1829,"src":"22512:9:12"},"referencedDeclaration":1829,"src":"22512:9:12","typeDescriptions":{"typeIdentifier":"t_enum$_Operation_$1829","typeString":"enum Operation"}},"visibility":"internal"},{"constant":false,"id":930,"mutability":"mutable","name":"_stRawNAV","nameLocation":"22544:9:12","nodeType":"VariableDeclaration","scope":947,"src":"22535:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":929,"nodeType":"UserDefinedTypeName","pathNode":{"id":928,"name":"NAV_UNIT","nameLocations":["22535:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"22535:8:12"},"referencedDeclaration":1840,"src":"22535:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":933,"mutability":"mutable","name":"_jtRawNAV","nameLocation":"22572:9:12","nodeType":"VariableDeclaration","scope":947,"src":"22563:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":932,"nodeType":"UserDefinedTypeName","pathNode":{"id":931,"name":"NAV_UNIT","nameLocations":["22563:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"22563:8:12"},"referencedDeclaration":1840,"src":"22563:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":936,"mutability":"mutable","name":"_ltRawNAV","nameLocation":"22600:9:12","nodeType":"VariableDeclaration","scope":947,"src":"22591:18:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":935,"nodeType":"UserDefinedTypeName","pathNode":{"id":934,"name":"NAV_UNIT","nameLocations":["22591:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"22591:8:12"},"referencedDeclaration":1840,"src":"22591:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":939,"mutability":"mutable","name":"_stSelfLiquidationBonusNAV","nameLocation":"22628:26:12","nodeType":"VariableDeclaration","scope":947,"src":"22619:35:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":938,"nodeType":"UserDefinedTypeName","pathNode":{"id":937,"name":"NAV_UNIT","nameLocations":["22619:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"22619:8:12"},"referencedDeclaration":1840,"src":"22619:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":941,"mutability":"mutable","name":"_enforceCoverageAndLiquidityRequirements","nameLocation":"22669:40:12","nodeType":"VariableDeclaration","scope":947,"src":"22664:45:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"},"typeName":{"id":940,"name":"bool","nodeType":"ElementaryTypeName","src":"22664:4:12","typeDescriptions":{"typeIdentifier":"t_bool","typeString":"bool"}},"visibility":"internal"}],"src":"22502:213:12"},"returnParameters":{"id":946,"nodeType":"ParameterList","parameters":[{"constant":false,"id":945,"mutability":"mutable","name":"state","nameLocation":"22779:5:12","nodeType":"VariableDeclaration","scope":947,"src":"22750:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":944,"nodeType":"UserDefinedTypeName","pathNode":{"id":943,"name":"SyncedAccountingState","nameLocations":["22750:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"22750:21:12"},"referencedDeclaration":1821,"src":"22750:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"22749:36:12"},"scope":1081,"src":"22466:320:12","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":948,"nodeType":"StructuredDocumentation","src":"22792:1273:12","text":" @notice Commits the liquidity tranche's freshly marked raw NAV\n @dev MUST be called by the kernel only after preOpSyncTrancheAccounting has committed the senior/junior NAVs AND the resulting\n      premium and protocol fee shares have been minted. This ordering is required for correctness: the fresh mark is read from the\n      AMM or another market-making venue oracle, whose senior leg is rate-scaled by the senior share rate (committed senior effective NAV over senior supply), so\n      only after the pre-op sync and its share mints does the mark reflect the final post-sync, post-mint senior state. Committing\n      it out of this order records a liquidity tranche raw NAV against a stale senior state\n @dev Committing the liquidity tranche raw NAV here, separately from the pre-op waterfall, is what keeps it out of the P&L\n      attribution and out of the senior share rate provider's dependency loop. The kernel derives the resulting liquidity\n      utilization from this mark and the synced senior effective NAV it already holds, avoiding an extra storage read\n @param _freshLtRawNAV The liquidity tranche's freshly marked raw NAV (the oracle value of the AMM or another market-making venue)"},"functionSelector":"d2995df4","id":954,"implemented":false,"kind":"function","modifiers":[],"name":"commitLiquidityTrancheRawNAV","nameLocation":"24079:28:12","nodeType":"FunctionDefinition","parameters":{"id":952,"nodeType":"ParameterList","parameters":[{"constant":false,"id":951,"mutability":"mutable","name":"_freshLtRawNAV","nameLocation":"24117:14:12","nodeType":"VariableDeclaration","scope":954,"src":"24108:23:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":950,"nodeType":"UserDefinedTypeName","pathNode":{"id":949,"name":"NAV_UNIT","nameLocations":["24108:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"24108:8:12"},"referencedDeclaration":1840,"src":"24108:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"24107:25:12"},"returnParameters":{"id":953,"nodeType":"ParameterList","parameters":[],"src":"24141:0:12"},"scope":1081,"src":"24070:72:12","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":955,"nodeType":"StructuredDocumentation","src":"24148:473:12","text":" @notice Returns the maximum assets depositable into the senior tranche without violating the market's coverage or liquidity requirements\n @dev Always rounds in favor of senior tranche protection\n @param state The synced accounting state that the maximum senior deposit is computed against\n @return maxDepositableNAV The maximum assets depositable into the senior tranche without violating the market's coverage or liquidity requirements"},"functionSelector":"bc3c08f5","id":964,"implemented":false,"kind":"function","modifiers":[],"name":"maxSTDeposit","nameLocation":"24635:12:12","nodeType":"FunctionDefinition","parameters":{"id":959,"nodeType":"ParameterList","parameters":[{"constant":false,"id":958,"mutability":"mutable","name":"state","nameLocation":"24677:5:12","nodeType":"VariableDeclaration","scope":964,"src":"24648:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":957,"nodeType":"UserDefinedTypeName","pathNode":{"id":956,"name":"SyncedAccountingState","nameLocations":["24648:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"24648:21:12"},"referencedDeclaration":1821,"src":"24648:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"24647:36:12"},"returnParameters":{"id":963,"nodeType":"ParameterList","parameters":[{"constant":false,"id":962,"mutability":"mutable","name":"maxDepositableNAV","nameLocation":"24716:17:12","nodeType":"VariableDeclaration","scope":964,"src":"24707:26:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":961,"nodeType":"UserDefinedTypeName","pathNode":{"id":960,"name":"NAV_UNIT","nameLocations":["24707:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"24707:8:12"},"referencedDeclaration":1840,"src":"24707:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"24706:28:12"},"scope":1081,"src":"24626:109:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":965,"nodeType":"StructuredDocumentation","src":"24741:565:12","text":" @notice Returns the maximum assets withdrawable from the junior tranche without violating the market's coverage requirement\n @dev Always rounds in favor of senior tranche protection\n @param state The synced accounting state that the maximum junior withdrawal is computed against\n @return stWithdrawableNAV The maximum claims on ST assets that the junior tranche can withdraw, denominated in NAV units\n @return jtWithdrawableNAV The maximum claims on JT assets that the junior tranche can withdraw, denominated in NAV units"},"functionSelector":"1b1b1efc","id":977,"implemented":false,"kind":"function","modifiers":[],"name":"maxJTWithdrawal","nameLocation":"25320:15:12","nodeType":"FunctionDefinition","parameters":{"id":969,"nodeType":"ParameterList","parameters":[{"constant":false,"id":968,"mutability":"mutable","name":"state","nameLocation":"25365:5:12","nodeType":"VariableDeclaration","scope":977,"src":"25336:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":967,"nodeType":"UserDefinedTypeName","pathNode":{"id":966,"name":"SyncedAccountingState","nameLocations":["25336:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"25336:21:12"},"referencedDeclaration":1821,"src":"25336:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"25335:36:12"},"returnParameters":{"id":976,"nodeType":"ParameterList","parameters":[{"constant":false,"id":972,"mutability":"mutable","name":"stWithdrawableNAV","nameLocation":"25404:17:12","nodeType":"VariableDeclaration","scope":977,"src":"25395:26:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":971,"nodeType":"UserDefinedTypeName","pathNode":{"id":970,"name":"NAV_UNIT","nameLocations":["25395:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"25395:8:12"},"referencedDeclaration":1840,"src":"25395:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":975,"mutability":"mutable","name":"jtWithdrawableNAV","nameLocation":"25432:17:12","nodeType":"VariableDeclaration","scope":977,"src":"25423:26:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":974,"nodeType":"UserDefinedTypeName","pathNode":{"id":973,"name":"NAV_UNIT","nameLocations":["25423:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"25423:8:12"},"referencedDeclaration":1840,"src":"25423:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"25394:56:12"},"scope":1081,"src":"25311:140:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":978,"nodeType":"StructuredDocumentation","src":"25457:447:12","text":" @notice Returns the maximum assets withdrawable from the liquidity tranche without violating the market's liquidity requirement\n @dev Always rounds in favor of senior tranche protection\n @param state The synced accounting state that the maximum liquidity withdrawal is computed against\n @return ltWithdrawableNAV The maximum market-making depth that the liquidity tranche can withdraw, denominated in NAV units"},"functionSelector":"2bf552e3","id":987,"implemented":false,"kind":"function","modifiers":[],"name":"maxLTWithdrawal","nameLocation":"25918:15:12","nodeType":"FunctionDefinition","parameters":{"id":982,"nodeType":"ParameterList","parameters":[{"constant":false,"id":981,"mutability":"mutable","name":"state","nameLocation":"25963:5:12","nodeType":"VariableDeclaration","scope":987,"src":"25934:34:12","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_memory_ptr","typeString":"struct SyncedAccountingState"},"typeName":{"id":980,"nodeType":"UserDefinedTypeName","pathNode":{"id":979,"name":"SyncedAccountingState","nameLocations":["25934:21:12"],"nodeType":"IdentifierPath","referencedDeclaration":1821,"src":"25934:21:12"},"referencedDeclaration":1821,"src":"25934:21:12","typeDescriptions":{"typeIdentifier":"t_struct$_SyncedAccountingState_$1821_storage_ptr","typeString":"struct SyncedAccountingState"}},"visibility":"internal"}],"src":"25933:36:12"},"returnParameters":{"id":986,"nodeType":"ParameterList","parameters":[{"constant":false,"id":985,"mutability":"mutable","name":"ltWithdrawableNAV","nameLocation":"26002:17:12","nodeType":"VariableDeclaration","scope":987,"src":"25993:26:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"},"typeName":{"id":984,"nodeType":"UserDefinedTypeName","pathNode":{"id":983,"name":"NAV_UNIT","nameLocations":["25993:8:12"],"nodeType":"IdentifierPath","referencedDeclaration":1840,"src":"25993:8:12"},"referencedDeclaration":1840,"src":"25993:8:12","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$1840","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"25992:28:12"},"scope":1081,"src":"25909:112:12","stateMutability":"view","virtual":false,"visibility":"external"},{"documentation":{"id":988,"nodeType":"StructuredDocumentation","src":"26027:300:12","text":" @notice Updates the JT YDM (Junior Tranche Yield Distribution Model) for this market\n @dev Only callable by a designated admin\n @param _jtYDM The new JT YDM address to set\n @param _jtYDMInitializationData The data used to initialize the new JT YDM for this market"},"functionSelector":"d5503018","id":995,"implemented":false,"kind":"function","modifiers":[],"name":"setJuniorTrancheYDM","nameLocation":"26341:19:12","nodeType":"FunctionDefinition","parameters":{"id":993,"nodeType":"ParameterList","parameters":[{"constant":false,"id":990,"mutability":"mutable","name":"_jtYDM","nameLocation":"26369:6:12","nodeType":"VariableDeclaration","scope":995,"src":"26361:14:12","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":989,"name":"address","nodeType":"ElementaryTypeName","src":"26361:7:12","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"},{"constant":false,"id":992,"mutability":"mutable","name":"_jtYDMInitializationData","nameLocation":"26392:24:12","nodeType":"VariableDeclaration","scope":995,"src":"26377:39:12","stateVariable":false,"storageLocation":"calldata","typeDescriptions":{"typeIdentifier":"t_bytes_calldata_ptr","typeString":"bytes"},"typeName":{"id":991,"name":"bytes","nodeType":"ElementaryTypeName","src":"26377:5:12","typeDescriptions":{"typeIdentifier":"t_bytes_storage_ptr","typeString":"bytes"}},"visibility":"internal"}],"src":"26360:57:12"},"returnParameters":{"id":994,"nodeType":"ParameterList","parameters":[],"src":"26426:0:12"},"scope":1081,"src":"26332:95:12","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":996,"nodeType":"StructuredDocumentation","src":"26433:303:12","text":" @notice Updates the LT YDM (Liquidity Tranche Yield Distribution Model) for this market\n @dev Only callable by a designated admin\n @param _ltYDM The new LT YDM address to set\n @param _ltYDMInitializationData The data used to initialize the new LT YDM for this market"},"functionSelector":"e85709d8","id":1003,"implemented":false,"kind":"function","modifiers":[],"name":"setLiquidityTrancheYDM","nameLocation":