:8:3"},"referencedDeclaration":971,"src":"31505:8:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":794,"mutability":"mutable","name":"navToMintSharesAt","nameLocation":"31539:17:3","nodeType":"VariableDeclaration","scope":799,"src":"31530:26:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":793,"nodeType":"UserDefinedTypeName","pathNode":{"id":792,"name":"NAV_UNIT","nameLocations":["31530:8:3"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"31530:8:3"},"referencedDeclaration":971,"src":"31530:8:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":797,"mutability":"mutable","name":"ltAssetsOut","nameLocation":"31571:11:3","nodeType":"VariableDeclaration","scope":799,"src":"31558:24:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":796,"nodeType":"UserDefinedTypeName","pathNode":{"id":795,"name":"TRANCHE_UNIT","nameLocations":["31558:12:3"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"31558:12:3"},"referencedDeclaration":973,"src":"31558:12:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"}],"src":"31504:79:3"},"scope":893,"src":"31336:248:3","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":800,"nodeType":"StructuredDocumentation","src":"31590:827:3","text":" @notice Atomically exits the liquidity tranche to the LT assets' constituent assets: proportionally removes the LT-asset slice,\n         redeems the venue-held senior shares to ST underlying, and returns (ST underlying + quote) to the receiver\n @param _ltShares The number of LT shares being redeemed (used to size the proportional LT-asset slice)\n @param _minSTSharesOut The minimum senior tranche shares the proportional removal must return (slippage bound)\n @param _minQuoteAssetsOut The minimum quote to return (slippage bound)\n @param _receiver The address that receives the ST underlying and quote\n @return stClaims The ST redemption asset claims transferred to the receiver (its ST/JT asset legs)\n @return quoteAssets The quote assets returned to the receiver"},"functionSelector":"c3947f02","id":816,"implemented":false,"kind":"function","modifiers":[],"name":"ltRedeemMultiAsset","nameLocation":"32431:18:3","nodeType":"FunctionDefinition","parameters":{"id":809,"nodeType":"ParameterList","parameters":[{"constant":false,"id":802,"mutability":"mutable","name":"_ltShares","nameLocation":"32467:9:3","nodeType":"VariableDeclaration","scope":816,"src":"32459:17:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":801,"name":"uint256","nodeType":"ElementaryTypeName","src":"32459:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":804,"mutability":"mutable","name":"_minSTSharesOut","nameLocation":"32494:15:3","nodeType":"VariableDeclaration","scope":816,"src":"32486:23:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":803,"name":"uint256","nodeType":"ElementaryTypeName","src":"32486:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":806,"mutability":"mutable","name":"_minQuoteAssetsOut","nameLocation":"32527:18:3","nodeType":"VariableDeclaration","scope":816,"src":"32519:26:3","stateVariable":false,"storageLocation":"default","typeDescri