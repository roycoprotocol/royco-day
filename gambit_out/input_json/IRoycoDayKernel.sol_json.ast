}},"visibility":"internal"}],"src":"32612:50:3"},"scope":893,"src":"32422:241:3","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":817,"nodeType":"StructuredDocumentation","src":"32783:533:3","text":" @notice Adds a senior tranche share and quote asset position into the liquidity venue and returns the liquidity tranche assets minted\n @param _seniorShares The exact amount of senior tranche shares to add into the liquidity venue\n @param _quoteAssets The exact amount of quote assets to add into the liquidity venue\n @param _minLTAssetsOut The minimum liquidity tranche assets that must be minted, bounding the add's slippage\n @return ltAssets The liquidity tranche assets minted by the add"},"functionSelector":"422f1043","id":830,"implemented":false,"kind":"function","modifiers":[],"name":"addLiquidity","nameLocation":"33330:12:3","nodeType":"FunctionDefinition","parameters":{"id":825,"nodeType":"ParameterList","parameters":[{"constant":false,"id":819,"mutability":"mutable","name":"_seniorShares","nameLocation":"33351:13:3","nodeType":"VariableDeclaration","scope":830,"src":"33343:21:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":818,"name":"uint256","nodeType":"ElementaryTypeName","src":"33343:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":821,"mutability":"mutable","name":"_quoteAssets","nameLocation":"33374:12:3","nodeType":"VariableDeclaration","scope":830,"src":"33366:20:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":820,"name":"uint256","nodeType":"ElementaryTypeName","src":"33366:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":824,"mutability":"mutable","name":"_minLTAssetsOut","nameLocation":"33401:15:3","nodeType":"VariableDeclaration","scope":830,"src":"33388:28:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":823,"nodeType":"UserDefinedTypeName","pathNode":{"id":822,"name":"TRANCHE_UNIT","nameLocations":["33388:12:3"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"33388:12:3"},"referencedDeclaration":973,"src":"33388:12:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"}],"src":"33342:75:3"},"returnParameters":{"id":829,"nodeType":"ParameterList","parameters":[{"constant":false,"id":828,"mutability":"mutable","name":"ltAssets","nameLocation":"33449:8:3","nodeType":"VariableDeclaration","scope":830,"src":"33436:21:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":827,"nodeType":"UserDefinedTypeName","pathNode":{"id":826,"name":"TRANCHE_UNIT","nameLocations":["33436:12:3"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"33436:12:3"},"referencedDeclaration":973,"src":"33436:12:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"}],"src":"33435:23:3"},"scope":893,"src":"33321:138:3","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":831,"nodeType":"StructuredDocumentation","src":"33465:780:3","text":" @notice Proportionally removes a slice of liquidity tranche assets from the liquidity venue into its senior tranche share and quote asset constituents\n @param _ltAssets The exact liquidity tranche assets to burn\n @param _minSTSharesOut The minimum senior tranche shares that must be withdrawn, bounding the removal's slippage\n @param _minQuoteAssetsOut The minimum quote assets that must be withdrawn, bounding the removal's slippage\n @param _quoteAssetsReceiver The recipient of the withdrawn quote assets. The withdrawn senior shares are returned to the kernel for the combined senior unwind\n @return stShares The senior tranche shares withdrawn by the removal\n @return quoteAssets The quote assets withdrawn by the removal"},"functionSelector":"e39b0eb5","id":847,"implemented":false,"kind":"function","modifiers":[],"name":"removeLiquidity","nameLocation":"34259:15:3","nodeType":"FunctionDefinition","parameters":{"id":841,"nodeType":"ParameterList","parameters":[{"constant":false,"id":834,"mutability":"mutable","name":"_ltAssets","nameLocation":"34297:9:3","nodeType":"VariableDeclaration","scope":847,"src":"34284:22:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":833,"nodeType":"UserDefinedTypeName","pathNode":{"id":832,"name":"TRANCHE_UNIT","nameLocations":["34284:12:3"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"34284:12:3"},"referencedDeclaration":973,"src":"34284:12:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"},{"constant":false,"id":836,"mutability":"mutable","name":"_minSTSharesOut","nameLocation":"34324:15:3","nodeType":"VariableDeclaration","scope":847,"src":"34316:23:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":835,"name":"uint256","nodeType":"ElementaryTypeName","src":"34316:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":838,"mutability":"mutable","name":"_minQuoteAssetsOut","nameLocation":"34357:18:3","nodeType":"VariableDeclaration","scope":847,"src":"34349:26:3","stateVariab