nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":755,"nodeType":"StructuredDocumentation","src":"28707:618:3","text":" @notice Processes the deposit of a specified amount of assets into the liquidity tranche.\n @dev An in-kind LT deposit mints no new senior shares and only deepens liquidity, so it is enabled in every market state (including fixed-term).\n @param _assets The amount of assets (the liquidity venue's position token) to deposit, denominated in the liquidity tranche's tranche units.\n @return valueAllocated The value of the assets deposited, denominated in the kernel's NAV units.\n @return navToMintSharesAt The NAV at which the shares will be minted, exclusive of valueAllocated."},"functionSelector":"8ae0db3e","id":767,"implemented":false,"kind":"function","modifiers":[],"name":"ltDeposit","nameLocation":"29339:9:3","nodeType":"FunctionDefinition","parameters":{"id":759,"nodeType":"ParameterList","parameters":[{"constant":false,"id":758,"mutability":"mutable","name":"_assets","nameLocation":"29362:7:3","nodeType":"VariableDeclaration","scope":767,"src":"29349:20:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":757,"nodeType":"UserDefinedTypeName","pathNode":{"id":756,"name":"TRANCHE_UNIT","nameLocations":["29349:12:3"],"nodeType":"IdentifierPath","referencedDeclaration":973,"src":"29349:12:3"},"referencedDeclaration":973,"src":"29349:12:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"}},"visibility":"internal"}],"src":"29348:22:3"},"returnParameters":{"id":766,"nodeType":"ParameterList","parameters":[{"constant":false,"id":762,"mutability":"mutable","name":"valueAllocated","nameLocation":"29398:14:3","nodeType":"VariableDeclaration","scope":767,"src":"29389:23:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":761,"nodeType":"UserDefinedTypeName","pathNode":{"id":760,"name":"NAV_UNIT","nameLocations":["29389:8:3"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"29389:8:3"},"referencedDeclaration":971,"src":"29389:8:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"},{"constant":false,"id":765,"mutability":"mutable","name":"navToMintSharesAt","nameLocation":"29423:17:3","nodeType":"VariableDeclaration","scope":767,"src":"29414:26:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"},"typeName":{"id":764,"nodeType":"UserDefinedTypeName","pathNode":{"id":763,"name":"NAV_UNIT","nameLocations":["29414:8:3"],"nodeType":"IdentifierPath","referencedDeclaration":971,"src":"29414:8:3"},"referencedDeclaration":971,"src":"29414:8:3","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_NAV_UNIT_$971","typeString":"NAV_UNIT"}},"visibility":"internal"}],"src":"29388:53:3"},"scope":893,"src":"29330:112:3","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":768,"nodeType":"StructuredDocumentation","src":"29448:342:3","text":" @notice Processes the redemption of a specified number of shares from the liquidity tranche.\n @param _shares The number of shares to redeem.\n @param _receiver The address that is receiving the assets.\n @return userAssetClaims The distribution of assets that were transferred to the receiver on redemption."},"functionSelector":"5c30fcf3","id":778,"implemented":false,"kind":"function","modifiers":[],"name":"ltRedeem","nameLocation":"29804:8:3","nodeType":"FunctionDefinition","parameters":{"id":773,"nodeType":"ParameterList","parameters":[{"constant":false,"id":770,"mutability":"mutable","name":"_shares","nameLocation":"29821:7:3","nodeType":"VariableDeclaration","scope":778,"src":"29813:15:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"},"typeName":{"id":769,"name":"uint256","nodeType":"ElementaryTypeName","src":"29813:7:3","typeDescriptions":{"typeIdentifier":"t_uint256","typeString":"uint256"}},"visibility":"internal"},{"constant":false,"id":772,"mutability":"mutable","name":"_receiver","nameLocation":"29838:9:3","nodeType":"VariableDeclaration","scope":778,"src":"29830:17:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"},"typeName":{"id":771,"name":"address","nodeType":"ElementaryTypeName","src":"29830:7:3","stateMutability":"nonpayable","typeDescriptions":{"typeIdentifier":"t_address","typeString":"address"}},"visibility":"internal"}],"src":"29812:36:3"},"returnParameters":{"id":777,"nodeType":"ParameterList","parameters":[{"constant":false,"id":776,"mutability":"mutable","name":"userAssetClaims","nameLocation":"29886:15:3","nodeType":"VariableDeclaration","scope":778,"src":"29867:34:3","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_AssetClaims_$1962_memory_ptr","typeString":"struct AssetClaims"},"typeName":{"id":775,"nodeType":"UserDefinedTypeName","pathNode":{"id":774,"name":"AssetClaims","nameLocations":["29867:11:3"],"nodeType":"IdentifierPath","referencedDeclaration":1962,"src":"29867:11:3"},"referencedDeclaration":1962,"src":"29867:11:3","typeDescriptions":{"typeIdentifier":"t_struct$_AssetClaims_$1962_storage_ptr","typeString":"struct AssetClaims"}},"visibility":"internal"}],"src":"29866:36:3"},"scope":893,"src":"29795:108:3","stateMutability":"nonpayable","virtual":false,"visibility":"external"},{"documentation":{"id":779,"nodeType":"StructuredDocumentation","src":"29909:1422:3","text":" @notice Atomically enters the liquidity tranche with the LT assets' constituent assets: deposits ST underlying (minting senior\n         shares), adds (senior shares + quote) into the liquidity venue to mint the LT tranche assets, then deposits them into the LT\n @dev Assumes the ST underlying and quote have been transferred to the kernel before this call (by the LT tranche)\n @dev Enabled in a PERPETUAL market state, and in a fixed-term market only for a quote-only deposit (_stAssets == 0) that mints no senior shares. An ST-leg deposit reverts in a fixed-term market\n @dev The combined new senior exposure is gated by the market's coverage and liquidity requirements. Reverts if either is unsatisfied\n @param _stAssets The amount of ST underlying (the senior tranche's base asset) to deposit, denominated in ST tranche units\n @param _quoteAssets The amount of quote asset to add as the second venue leg\n @param _minLTAssetsOut The minimum LT tranche assets the liquidity add must mint (slippage bound against an unfavorable venue state)\n @return valueAllocated The value of the minted LT tranche assets, denominated in the kernel's NAV units\n @return navToMintSharesAt The LT effective NAV at which the LT shares will be minted (pre-deposit)\n @return ltAssetsOut The amount of LT tranche assets minted and credited to the liquidity tranche"},"functionSelector":"aaabd740","id":799,"implemented":false,"kind":"function","modifiers":[],"name":"ltDepositMultiAsset","nameLocation":"31345:19:3","nodeType":"FunctionDefinition","parameters":{"id":788,"nodeType":"ParameterList","parameters":[{"constant":false,"id":782,"mutability":"mutable","name":"_stAssets","nameLocation":"31387:9:3","nodeType":"VariableDeclaration","scope":799,"src":"31374:22:3","stateVariable":false,"storageLocation":"default","typeDescriptions":{"typeIdentifier":"t_userDefinedValueType$_TRANCHE_UNIT_$973","typeString":"TRANCHE_UNIT"},"typeName":{"id":781,"nodeType":"UserDefinedTypeName","pathNode":{"id":780,"name":"TRANCHE_UNIT","nameLocations":["31374:12:3"],"nodeType":"IdentifierPath","referencedDeclarati