quidity premium and protocol fees are minted"},"id":218,"implemented":true,"kind":"function","modifiers":[],"name":"_processFeesAndLiquidityPremium","nameLocation":"1869:31:14","nodeType":"FunctionDefinition","parameters":{"id":35,"nodeType":"ParameterList","parameters":[{"constant":false,"id":28,"mutability":"mutable","name":"$","nameLocation":"1954:1:14","nodeType":"VariableDeclaration","scope":218,"src":"1910:45:14","stateVariable":false,"storageLocation":"storage","typeDescriptions":{"typeIdentifier":"t_struct$_RoycoDayKernelState_$418_storage_ptr","typeString":"struct IRoycoDayKernel.RoycoDayKernelState"},"typeName":{"id":27,"nodeType":"UserDefinedTypeName","pathNode":{"id":26,"name":"IRoycoDayKernel.RoycoDayKernelState","nameLocations":["1910:15:14","1926:19:14"],"nodeType":"IdentifierPath","referencedDeclaration":418,"src":"1910:35:14"},"referencedDeclaration":418,"src":"1910:35:14","typeDescriptions":{"typeIdentifier":"t_struct$_RoycoDayKernelState_$418_storage_ptr","typeString":"struct IRoycoDayKernel.RoycoDayKernelState"}},"visibility":"internal"},{"constant":false,"id":31,"mutability":"mutable","name":"_immutables","nameLocation":"2017:11:14","nodeType":"VariableDeclaration","scope":218,"src":"1965:63:14","stateVariable":false,"storageLocation":"memory","typeDescriptions":{"typeIdentifier":"t_struct$_RoycoDayKernelImmutableState_$434_memory_ptr","typeString":"struct IRoycoDayKernel.RoycoDayKernelImmutableState"},"typeName":{"id":30,"nodeType":"UserDefinedTypeName","pathNode":{"id":29,"name":"IRoycoDayKernel.RoycoDayKernelImmutableState","nameLocations":["1965:15:14","1981:28:14"],"nodeType":"IdentifierPath","referencedDeclaration":434,"src":"1965:44:14"},"referencedDeclaration":434,"src":"1965:44:14","typeDescriptions":{"typeIdentifier":"t_struct$_RoycoDayKernelImmutableState_$434_storage_ptr","typeString":"struct IRoycoDayKernel.RoycoDayKernelImmutableState"}},"visibility":"internal"},{"constant":false,"id":34,"mutability":"mutable","name":"_state","name